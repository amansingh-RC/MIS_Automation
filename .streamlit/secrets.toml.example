# RCL MIS Automation — email settings
# --------------------------------------------------------------------------
# 1. Copy this file to  .streamlit/secrets.toml
# 2. Fill in the values below.
# secrets.toml is gitignored — never commit real credentials.

[smtp]
host = "smtp.gmail.com"
port = 587
use_tls = true          # STARTTLS (Gmail on port 587)
use_ssl = false         # set true (and port 465) only for implicit SSL
user = "you@royalchains.com"
# Gmail/Workspace: create a 16-char App Password at
# Google Account -> Security -> 2-Step Verification -> App passwords.
password = "your-16-char-app-password"
from_addr = "you@royalchains.com"
from_name = "RCL MIS Automation"

[mail]
# Default "Send to" address shown (and editable) in each tab.
combined_to = "recipient@royalchains.com"
manish_to = "manish@royalchains.com"
